# https://editorconfig.org — consistent formatting across editors.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.rs]
indent_size = 4

[*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc,css,html}]
indent_size = 2

[*.{yml,yaml,toml}]
indent_size = 2

[*.py]
indent_size = 4

[*.md]
# two trailing spaces are a hard line break in Markdown
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
